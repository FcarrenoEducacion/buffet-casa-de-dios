# Variables de entorno para Buffet Casa de Dios (Producción Vercel)

# Credenciales de Supabase para el Servidor Backend (Express)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Credenciales de Supabase para el Cliente (si aplica o se desea en el futuro)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API Key de Gemini para el Asistente "Ángel del Sabor"
GEMINI_API_KEY=

# URL Pública de Producción (Vercel) para generación de Códigos QR de las mesas
# Ejemplo: https://buffet-casa-de-dios.vercel.app
VITE_PUBLIC_APP_URL=
PUBLIC_APP_URL=
